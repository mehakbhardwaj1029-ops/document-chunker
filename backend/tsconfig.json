{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": "api/src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": ["api/src"],
  "exclude": ["node_modules", "dist"]
}
